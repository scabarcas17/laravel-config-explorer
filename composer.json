{
    "name": "scabarcas/laravel-config-explorer",
    "description": "Browse and search Laravel's runtime config() tree in the browser. For local debugging.",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3",
        "laravel/pint": "1.29.1",
        "laravel/framework": "^12.0|^13.0",
        "orchestra/testbench": "^10.11|^11.0"
    },
    "license": "MIT",
    "keywords": [
        "laravel",
        "config",
        "configuration",
        "explorer",
        "phpinfo",
        "debugging",
        "developer-tools",
        "dev-tools",
        "inspector"
    ],
    "autoload": {
        "psr-4": {
            "Scabarcas\\LaravelConfigExplorer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scabarcas\\LaravelConfigExplorer\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sebastian Cabarcas",
            "email": "sebastianberrio45@hotmail.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=80",
        "format": "pint",
        "analyse": "phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Scabarcas\\LaravelConfigExplorer\\ConfigExplorerServiceProvider"
            ]
        }
    }
}
